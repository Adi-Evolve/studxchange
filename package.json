{
  "name": "studxchange",
  "version": "1.0.0",
  "description": "A platform for students to buy, sell, and exchange items within their college community",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "minify-js": "uglifyjs public/js/db-config.js public/js/navbar.js -o public/dist/scripts.min.js",
    "build": "npm run minify-js"
  },
  "keywords": [
