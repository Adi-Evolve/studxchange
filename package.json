    "exchange",
    "academic",
    "resources"
  ],
  "author": "Adi-Evolve",
  "license": "MIT",
  "dependencies": {
    "body-parser": "^1.20.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "maplibre-gl": "^5.3.0",
    "mongoose": "^7.5.0",
    "nodemailer": "^6.9.5",
    "string-similarity": "^4.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "babel-loader": "^10.0.0",
    "clean-css-cli": "^5.6.3",
    "express-rate-limit": "^7.5.0",
    "nodemon": "^3.0.1",
    "uglify-js": "^3.19.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
